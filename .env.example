# App
APP_NAME=Spektra
APP_ENV=local
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
REQUIRE_EMAIL_VERIFICATION=false

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=spektra
DB_USERNAME=spektra_user
DB_PASSWORD=spektra_pass
DATABASE_URL=
DB_SSLMODE=prefer

# Optional host port forwarding for docker-compose.expose.yml only.
DB_FORWARD_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_FORWARD_PORT=6379

# External providers
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
RAWG_API_KEY=
RAWG_BASE_URL=https://api.rawg.io/api
OPENLIBRARY_BASE_URL=https://openlibrary.org
YOUTUBE_API_KEY=

# Mail
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@spektra.local
MAIL_FROM_NAME=Spektra

# Frontend public URL
VITE_API_URL=http://localhost:8000/api
VITE_PUBLIC_SITE_URL=http://localhost:5173

# Analytics / Monitoring
VITE_ANALYTICS_PROVIDER=none
VITE_GA_MEASUREMENT_ID=
VITE_UMAMI_SRC=
VITE_UMAMI_WEBSITE_ID=
VITE_SENTRY_DSN=
