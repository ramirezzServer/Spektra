APP_NAME=Spektra
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
REQUIRE_EMAIL_VERIFICATION=false
SANCTUM_TOKEN_EXPIRATION_MINUTES=1440
HEALTH_CHECK_SECRET=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DATABASE_URL=
